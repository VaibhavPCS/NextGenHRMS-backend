generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// -------------------------------------------------------------
// TABLE 1: THE STAGING AREA (Transient Onboarding Data)
// -------------------------------------------------------------
model OnboardingCandidate {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  
  // Basic Identity
  personalEmail       String   @unique
  phoneNumber         String?  @unique
  firstName           String?
  lastName            String?
  emergencyContact    String?
  bloodGroup          String?
  photoUrl            String?
  jobTier             JobTier  @default(SKILLED) 
  
  // Government IDs
  aadharNumber        String?
  aadharHash          String?
  aadharUrl           String?
  panNumber           String?
  panHash             String?
  panUrl              String?
  passportUrl         String?  // <-- Add this back in!
  
  // Statutory & Fresher Check
  isFirstTimeEmployee Boolean  @default(true) // Checkbox to bypass experience uploads
  uanNumber           String?                 // Universal Account Number for PF

  // Academic Documents (URIs)
  tenthCertUrl        String?
  twelfthCertUrl      String?
  degreeCertUrls      String[] // Array for UG/PG/Diploma
  skillCertUrls       String[]
  
  // ---------------------------------------------------------
  // THE EXPERIENCE VAULT (For non-freshers)
  // ---------------------------------------------------------
  totalClaimedExperience Float?   // e.g., 4.5 years
  
  // Immediate Past Employment (CTC Mapping)
  pastOfferLetterUrl     String?  
  incrementLetterUrls    String[] // Array for all subsequent hikes
  
  // Comprehensive Record (BGV)
  relievingLetterUrls    String[] // From ALL prior organizations
  
  // Financials & TDS
  salarySlipUrls         String[] // Last 3 months
  bankStatementUrl       String?  // 1-year statement
  form16Url              String?  // Crucial for current FY TDS
  
  // ---------------------------------------------------------
  // POST-OFFER COMPLIANCE
  // ---------------------------------------------------------
  // Phase 3: Resignation
  resignationProofUrl    String?  // Acceptance email from current employer
  
  // Phase 5: Corporate Banking
  bankAccountNumber      String?
  bankIfscCode           String?
  
  // ---------------------------------------------------------
  // SECURITY & STATE MACHINE
  // ---------------------------------------------------------
  onboardingStatus    OnboardingStatus @default(INVITE_SENT)
  inviteToken         String?
  tokenExpiry         DateTime?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// -------------------------------------------------------------
// TABLE 2: THE FINANCIAL LEDGER (Active Employees Only)
// -------------------------------------------------------------
model Employee {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  authId           String   @unique 
  phoneNumber      String   @unique
  companyEmail     String   @unique
  onboardingStatus String   @default("ACTIVE")
  
  createdAt        DateTime @default(now())
}

// -------------------------------------------------------------
// ENUMS (Strict Phase Tracking)
// -------------------------------------------------------------
enum OnboardingStatus {
  INVITE_SENT           // Link generated by HR
  DOCS_UPLOADED         // Candidate uploaded Aadhar, PAN, Form 16, etc.
  OFFER_ROLLED          // HR validated docs & UP Labor Laws, sent offer
  OFFER_ACCEPTED        // Candidate accepted within 48 hours
  RESIGNATION_VERIFIED  // RM/HR approved the resignation proof
  BGV_CLEARED           // IDfy/Manual checks passed
  BANK_DETAILS_SUBMITTED// Penny drop verified
  ACTIVE                // Transitioned to Employee Master
  REJECTED              // Failed at any stage
}

enum JobTier {
  UNSKILLED       // Max 10th required
  SEMI_SKILLED    // Max 12th required
  SKILLED         // Degree required
  PROFESSIONAL    // Degree + Experience required
}